# Git ignore — Liaotao desktop baseline

# Runtime dirs (auto-created)
logs/
reports/
.tmp/

# System specific
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
*~

# Editor
.vscode/settings.json
.idea/
*.swp
*.swo

# Env overrides (never commit)
*.env
.env
.env.*
!.env.example
user.toml
*.user.toml
*.pem
*.key
id_rsa
id_ed25519

# JVM / Gradle / Kotlin
.gradle/
build/
*/build/
out/
*.class

# Native packaging outputs
dist/

# Legacy Go/Wails leftovers to ignore if recreated during transition
/bin/
*.exe
*.exe~
*.dll
*.so
*.dylib
frontend/dist/
frontend/node_modules/
wailsjs/
