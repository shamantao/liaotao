# Git ignore — wails-go adapter additions (merged on top of template-core .gitignore)

# Go
/build/*
!/build/config.yml
/bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Wails
frontend/dist/
frontend/node_modules/
wailsjs/

# Go test cache
*.test
*.out

# Runtime data
/logs/
/data/

# System specific
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# docs (local only — contains proprietary roadmap)
docs/backlog-liaotao.md
docs/PRD-liaotao.md

# kDrive / cloud-sync conflict files (created on simultaneous edit from two machines)
*_conflict_*

# Compiled binary
liaotao
